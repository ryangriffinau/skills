#!/usr/bin/env bash
# Compute Beads -> Linear MCP operations from .flywheel/projects.tsv.
# This is compute-only: it never calls Linear or any MCP tool.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  echo "usage: beads-linear-projector --repo DIR" >&2
}

repo="."
while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      repo="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

if ! repo_abs="$(cd "$repo" 2>/dev/null && pwd)"; then
  echo "beads-linear-projector: repo not found: $repo" >&2
  exit 2
fi

profile="$repo_abs/.flywheel/profile"
projects_tsv="$repo_abs/.flywheel/projects.tsv"
issues_jsonl="$repo_abs/.beads/issues.jsonl"

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

raw_projection_app() {
  local line value
  [ -f "$profile" ] || return 0
  line="$(grep -E '^FLYWHEEL_PROJECTION_APP=' "$profile" | tail -n 1 || true)"
  [ -n "$line" ] || return 0
  value="${line#FLYWHEEL_PROJECTION_APP=}"
  value="${value%%#*}"
  printf '%s' "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

emit_empty_payload() {
  local reason="$1"
  printf '{\n'
  printf '  "app": "linear",\n'
  printf '  "mode": "compute",\n'
  printf '  "repo": "%s",\n' "$(json_escape "$repo_abs")"
  printf '  "operations": [],\n'
  printf '  "warnings": ["%s"],\n' "$(json_escape "$reason")"
  printf '  "apply": "Run these operations from an agent or human session with the Linear MCP; Codex workers do not apply them."\n'
  printf '}\n'
}

resolved="$("$SCRIPT_DIR/flywheel-profile.sh" --repo "$repo_abs")"
eval "$resolved"

raw_app="$(raw_projection_app)"
if [ -n "$raw_app" ] && [ "$raw_app" != "linear" ]; then
  echo "beads-linear-projector: unsupported FLYWHEEL_PROJECTION_APP=$raw_app; continuing without applying" >&2
  emit_empty_payload "unsupported projection app: $raw_app"
  exit 0
fi

if [ "${FLYWHEEL_PROJECTION_APP:-}" = "" ]; then
  exit 0
fi

if [ ! -f "$projects_tsv" ]; then
  echo "beads-linear-projector: FLYWHEEL_PROJECTION_APP=linear but .flywheel/projects.tsv is missing; continuing" >&2
  emit_empty_payload "missing .flywheel/projects.tsv"
  exit 0
fi

if [ ! -f "$issues_jsonl" ]; then
  echo "beads-linear-projector: .beads/issues.jsonl not found; continuing" >&2
  emit_empty_payload "missing .beads/issues.jsonl"
  exit 0
fi

awk -v repo="$repo_abs" '
function esc(s) {
  gsub(/\\/, "\\\\", s)
  gsub(/"/, "\\\"", s)
  gsub(/\t/, "\\t", s)
  gsub(/\r/, "", s)
  return s
}

function field(line, key, pattern, value) {
  pattern = "\"" key "\":\""
  if (index(line, pattern) == 0) {
    return ""
  }
  value = substr(line, index(line, pattern) + length(pattern))
  sub(/".*/, "", value)
  return value
}

function numeric_field(line, key, pattern, value) {
  pattern = "\"" key "\":"
  if (index(line, pattern) == 0) {
    return ""
  }
  value = substr(line, index(line, pattern) + length(pattern))
  sub(/[^0-9].*/, "", value)
  return value
}

FILENAME == ARGV[1] {
  if ($0 ~ /^[[:space:]]*($|#)/) {
    next
  }
  split($0, cols, "\t")
  if (cols[1] != "" && cols[2] != "") {
    project[cols[1]] = cols[2]
    epic_order[++epic_count] = cols[1]
  }
  next
}

FILENAME == ARGV[2] {
  id = field($0, "id")
  title = field($0, "title")
  status = field($0, "status")
  issue_type = field($0, "issue_type")
  priority = numeric_field($0, "priority")
  if (id == "") {
    next
  }
  for (i = 1; i <= epic_count; i++) {
    epic = epic_order[i]
    if (id == epic || index(id, epic ".") == 1) {
      op_id[++op_count] = id
      op_title[op_count] = title
      op_status[op_count] = status
      op_type[op_count] = issue_type
      op_priority[op_count] = priority
      op_epic[op_count] = epic
      op_project[op_count] = project[epic]
      break
    }
  }
}

END {
  printf "{\n"
  printf "  \"app\": \"linear\",\n"
  printf "  \"mode\": \"compute\",\n"
  printf "  \"repo\": \"%s\",\n", esc(repo)
  printf "  \"operations\": [\n"
  for (i = 1; i <= op_count; i++) {
    printf "    {\n"
    printf "      \"op\": \"upsert_issue\",\n"
    printf "      \"source\": {\"system\": \"beads\", \"id\": \"%s\", \"epic\": \"%s\"},\n", esc(op_id[i]), esc(op_epic[i])
    printf "      \"linearMcp\": {\n"
    printf "        \"action\": \"upsertIssue\",\n"
    printf "        \"projectId\": \"%s\",\n", esc(op_project[i])
    printf "        \"externalId\": \"beads:%s\",\n", esc(op_id[i])
    printf "        \"title\": \"%s\",\n", esc(op_title[i])
    printf "        \"status\": \"%s\",\n", esc(op_status[i])
    printf "        \"priority\": \"%s\",\n", esc(op_priority[i])
    printf "        \"issueType\": \"%s\"\n", esc(op_type[i])
    printf "      }\n"
    printf "    }%s\n", (i < op_count ? "," : "")
  }
  printf "  ],\n"
  printf "  \"apply\": \"Run these operations from an agent or human session with the Linear MCP; Codex workers do not apply them.\"\n"
  printf "}\n"
}
' "$projects_tsv" "$issues_jsonl"
